{
  "name": "weave-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test VITEST=true vitest",
    "test:unit": "NODE_ENV=test VITEST=true vitest --run",
    "test:watch": "NODE_ENV=test VITEST=true vitest --watch",
    "test:coverage": "NODE_ENV=test VITEST=true vitest --coverage",
    "test:ui": "NODE_ENV=test VITEST=true vitest --ui",
    "test:server": "NODE_ENV=test npx tsx src/index.ts",
    "migrate:templates": "npx tsx scripts/migrate-templates.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.1.2",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
