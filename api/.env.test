# API Test Environment Configuration
# This file is loaded automatically by vitest for all API tests

# API Server Configuration
PORT=3001
API_BEARER_TOKEN=test-token-for-testing-only

# Test Database Configuration
TEST_DB_PATH=./api/data/test-database.db
TEST_DB_TYPE=sqlite
TEST_DB_LOGGING=false

# Agent Client Configuration
DATA_DIR=/tmp/test-agent-client

# Test Execution Configuration
NODE_ENV=test
TEST_TIMEOUT=30000
TEST_CLEANUP_ENABLED=true

# Test Data Configuration
SEED_TEST_DATA=true
CLEANUP_TEST_DATA=true

# Logging Configuration
LOG_LEVEL=error
TEST_LOG_PATH=/tmp/api-test-logs

# API Configuration for Testing
API_URL=http://localhost:3001
API_TIMEOUT_MS=5000

# Project Configuration
PROJECT_ROOT=/root/projects/weave
TEST_PROJECTS_DIR=/tmp/test-projects

# Approval Configuration for Testing
APPROVAL_TIMEOUT_MINUTES=1

# Test Server Configuration
TEST_SERVER_PORT=3001
TEST_SERVER_HOST=localhost

# Mock Configuration
USE_MOCK_AGENTS=true
USE_MOCK_EXTERNAL_SERVICES=true
MOCK_AGENT_DELAY_MS=100
