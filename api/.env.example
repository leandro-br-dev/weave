# Database path is automatically computed based on APP_ENV:
#   Production: ~/.local/share/weave/database.db
#   Development: ~/.local/share/weave-dev/database.db
# Override with DATABASE_URL if needed (legacy support only)

PORT=3000

# Authentication
API_BEARER_TOKEN=change-me
WEAVE_TOKEN=change-me

# Data directory override (optional)
# Defaults to ~/.local/share/weave/ (or ~/.local/share/weave-dev/ for APP_ENV=dev)
# DATA_DIR=/custom/path

# CORS Configuration (origens permitidas para acessar a API)
# Adicione os domínios permitidos separados por vírgula
# Exemplo para Cloudflare Tunnel:
# ALLOWED_ORIGINS=https://weave.seudominio.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
