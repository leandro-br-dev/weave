# Integration Test Environment Configuration
# Copy this file to .env.test.local and customize for your environment

# API Configuration
API_URL=http://localhost:3000
AUTH_TOKEN=dev-token-change-in-production

# Database Configuration
TEST_DB_PATH=./api/data/test-database.db
PROD_DB_PATH=./api/data/database.db

# Test Data Configuration
CLEANUP_AFTER_TEST=true
SEED_TEST_DATA=true

# Test Timeout Configuration
TEST_TIMEOUT_MS=30000
API_READY_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
VERBOSE_LOGGING=false

# Project Configuration
PROJECT_ROOT=/root/projects/weave
TEST_PROJECTS_DIR=/tmp/test-projects
