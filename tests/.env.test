# Python Test Environment Configuration
# This file is loaded automatically by pytest for all Python tests

# Test Database Configuration
TEST_DB_TYPE=sqlite
TEST_DB_PATH=/tmp/weave-test.db
TEST_DB_LOGGING=false

# API Configuration for Testing
TEST_API_URL=http://localhost:3000
TEST_API_TOKEN=test-token-for-testing-only
TEST_API_TIMEOUT=5000

# Test Project Configuration
TEST_PROJECTS_DIR=/tmp/test-projects
TEST_WORKSPACE_DIR=/tmp/test-workspaces

# Test Execution Configuration
TEST_TIMEOUT=30
TEST_CLEANUP_ENABLED=true
TEST_VERBOSE_LOGGING=false

# Test Data Configuration
TEST_SEED_DATA=true
TEST_DATA_CLEANUP=true

# Logging Configuration
LOG_LEVEL=ERROR
TEST_LOG_PATH=/tmp/test-logs

# Approval Configuration for Testing
TEST_APPROVAL_TIMEOUT_MINUTES=1
TEST_AUTO_APPROVE=false

# Mock Configuration
USE_MOCK_AGENTS=true
USE_MOCK_EXTERNAL_SERVICES=true
