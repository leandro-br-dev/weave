{
  "name": "weave",
  "version": "0.5.0",
  "description": "AI agent orchestration platform",
  "scripts": {
    "install:all": "npm install --prefix api && npm install --prefix dashboard",
    "dev:api": "npm run dev --prefix api",
    "dev:dashboard": "npm run dev --prefix dashboard",
    "build:all": "npm run build --prefix api && npm run build --prefix dashboard",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:dashboard\"",
    "test": "npm run test:all",
    "test:all": "./scripts/test-runner.sh all",
    "test:e2e": "./tests/scripts/e2e/test-improvement-comprehensive.sh",
    "test:workflow": "./tests/scripts/workflow/test-improvement-workflow.sh && ./tests/scripts/workflow/test-structured-output-race-condition.sh && ./tests/scripts/workflow/test-structured-output-fix.sh",
    "test:scripts": "./tests/scripts/e2e/test-improvement-comprehensive.sh && ./tests/scripts/workflow/test-improvement-workflow.sh",
    "test:manual": "./tests/scripts/manual/test-improvement-manual.sh",
    "test:python": "cd tests && pytest -v",
    "test:python:unit": "cd tests && pytest tests/unit -v",
    "test:python:integration": "cd tests && pytest tests/integration -v",
    "test:python:coverage": "cd tests && pytest --cov=client --cov-report=html --cov-report=term-missing --cov-report=json",
    "test:api": "npm run test --prefix api",
    "test:api:unit": "npm run test --prefix api -- --run",
    "test:api:watch": "npm run test --prefix api -- --watch",
    "test:api:coverage": "npm run test --prefix api -- --coverage",
    "test:dashboard": "npm run test --prefix dashboard",
    "test:dashboard:watch": "npm run test --prefix dashboard -- --watch",
    "test:dashboard:coverage": "npm run test --prefix dashboard -- --coverage",
    "test:integration": "vitest --config tests/integration/vitest.config.ts --run",
    "test:integration:watch": "vitest --config tests/integration/vitest.config.ts --watch",
    "test:unit": "npm run test:python:unit && npm run test:api:unit",
    "test:coverage": "./scripts/test-coverage.sh",
    "test:watch": "./scripts/test-watch.sh",
    "test:ci": "./scripts/test-runner.sh ci",
    "test:setup": "./scripts/setup-test-env.sh",
    "test:teardown": "./scripts/teardown-test-env.sh",
    "test:reset-db": "./scripts/reset-test-db.sh",
    "test:clean": "rm -rf coverage .coverage coverage-* tests/.pytest_cache api/coverage dashboard/coverage tests/integration/coverage",
    "check:docs": "./scripts/check-root-md.sh",
    "precommit": "npm run check:docs"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16"
  }
}
