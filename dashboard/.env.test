# Dashboard Test Environment Configuration
# This file is loaded automatically by vitest for all Dashboard tests

# API Configuration for Testing
VITE_API_URL=http://localhost:3001
VITE_API_TOKEN=test-token-for-testing-only

# Test Server Configuration
VITE_TEST_SERVER_PORT=5174
VITE_TEST_SERVER_HOST=localhost

# Test Execution Configuration
NODE_ENV=test
VITE_TEST_TIMEOUT=10000
VITE_TEST_CLEANUP_ENABLED=true

# Mock Configuration
VITE_USE_MOCK_API=false
VITE_MOCK_DELAY_MS=100

# Component Testing Configuration
VITE_COMPONENT_TEST_TIMEOUT=5000
VITE_USER_EVENT_TIMEOUT=3000

# Browser Testing Configuration
VITE_BROWSER_TIMEOUT=30000
VITE_HEADLESS=true

# Test Data Configuration
VITE_SEED_TEST_DATA=true
VITE_USE_TEST_FIXTURES=true

# Logging Configuration
VITE_LOG_LEVEL=error
VITE_DEBUG_MODE=false

# Feature Flags for Testing
VITE_ENABLE_WEBSOCKETS=false
VITE_ENABLE_AUTO_REFRESH=false
VITE_ENABLE_ERROR_BOUNDARIES=true
